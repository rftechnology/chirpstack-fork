# Copy to .env.production in the repo root (or pass --env-file) and edit.
# After mirroring images to ECR, set each *_IMAGE to your full URI (registry/repo:tag).

# --- ChirpStack application (built by your pipeline, pushed to ECR) ---
CHIRPSTACK_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/chirpstack:4.17.0
CHIRPSTACK_API_BIND=8080

# Directory on the host containing chirpstack *.toml (must include DSNs and integration endpoints
# matching the Compose service names: postgres, redis, mosquitto, rabbitmq, kafka).
CHIRPSTACK_CONFIG_DIR=./chirpstack/configuration

# --- Dependencies (mirror these from Docker Hub / public registries into ECR) ---
# Dockerfiles to build/push your own copies: deploy/docker/postgres, redis, eclipse-mosquitto, rabbitmq, apache-kafka
POSTGRES_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/postgres:18-alpine
REDIS_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/redis:8-alpine
MOSQUITTO_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/eclipse-mosquitto:2
RABBITMQ_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/rabbitmq:4-management-alpine
KAFKA_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/apache/kafka:4.1.0

# Mosquitto config directory (host path). Example: repo's minimal dev config (not for real prod).
MOSQUITTO_CONFIG_DIR=./.docker-compose/mosquitto/config

POSTGRES_USER=chirpstack
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=chirpstack

RABBITMQ_USER=chirpstack
RABBITMQ_PASSWORD=change-me-strong-password
